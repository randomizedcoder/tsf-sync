From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: tsf-sync contributors <tsf-sync@users.noreply.github.com>
Date: Tue, 1 Apr 2026 00:00:00 +0000
Subject: [PATCH] wifi: mt76: add PTP hardware clock for TSF synchronization

Register a PTP hardware clock (/dev/ptpN) for mt76-based devices,
exposing the 802.11 TSF timer to the Linux PTP subsystem. This enables
phc2sys to synchronize TSF counters across co-located radios.

PTP clock operations access TSF via the common mt76 register I/O layer.
Each chipset stores TSF in different registers, so per-chipset callbacks
are used:
  - mt7915/mt7916/mt7986: MT_LPON_UTTR0/UTTR1 (direct register)
  - mt7996: register-based TSF
  - mt7921/mt7922/mt7925: MCU firmware commands

The PTP clock is registered at the common mt76_dev level and uses
per-chipset tsf_read/tsf_write callbacks for hardware abstraction.

TSF is in microseconds (802.11); PTP is in nanoseconds.

Signed-off-by: tsf-sync contributors <tsf-sync@users.noreply.github.com>
---
 drivers/net/wireless/mediatek/mt76/Makefile   |   1 +
 drivers/net/wireless/mediatek/mt76/mt76.h     |  17 +++
 drivers/net/wireless/mediatek/mt76/mac80211.c |   4 +
 drivers/net/wireless/mediatek/mt76/ptp.c      | 142 ++++++++++++++++++++
 4 files changed, 164 insertions(+)
 create mode 100644 drivers/net/wireless/mediatek/mt76/ptp.c

diff --git a/drivers/net/wireless/mediatek/mt76/Makefile b/drivers/net/wireless/mediatek/mt76/Makefile
--- a/drivers/net/wireless/mediatek/mt76/Makefile
+++ b/drivers/net/wireless/mediatek/mt76/Makefile
@@ -14,6 +14,7 @@ mt76-y := \
 
 mt76-$(CONFIG_PCI) += pci.o
 mt76-$(CONFIG_NL80211_TESTMODE) += testmode.o
+mt76-$(CONFIG_PTP_1588_CLOCK) += ptp.o
 
 mt76-usb-y := usb.o usb_trace.o
 mt76-sdio-y := sdio.o sdio_txrx.o
diff --git a/drivers/net/wireless/mediatek/mt76/mt76.h b/drivers/net/wireless/mediatek/mt76/mt76.h
--- a/drivers/net/wireless/mediatek/mt76/mt76.h
+++ b/drivers/net/wireless/mediatek/mt76/mt76.h
@@ -13,6 +13,7 @@
 #include <linux/leds.h>
 #include <linux/usb.h>
 #include <linux/average.h>
+#include <linux/ptp_clock_kernel.h>
 #include <linux/soc/mediatek/mtk_wed.h>
 #include <net/mac80211.h>
 #include <net/page_pool/helpers.h>
@@ -646,6 +647,12 @@ struct mt76_sdio {
 	int (*parse_irq)(struct mt76_dev *dev, struct mt76s_intr *intr);
 };
 
+/* Per-chipset TSF access callbacks for PTP clock. */
+struct mt76_ptp_ops {
+	u64 (*tsf_read)(struct mt76_dev *dev);
+	void (*tsf_write)(struct mt76_dev *dev, u64 tsf);
+};
+
 struct mt76_mmio {
 	void __iomem *regs;
 	spinlock_t irq_lock;
@@ -923,4 +931,10 @@ struct mt76_dev {
 		struct mt76_sdio sdio;
 	};
+
+#if IS_ENABLED(CONFIG_PTP_1588_CLOCK)
+	struct ptp_clock *ptp_clock;
+	struct ptp_clock_info ptp_info;
+	const struct mt76_ptp_ops *ptp_ops;
+#endif
 };

diff --git a/drivers/net/wireless/mediatek/mt76/mac80211.c b/drivers/net/wireless/mediatek/mt76/mac80211.c
--- a/drivers/net/wireless/mediatek/mt76/mac80211.c
+++ b/drivers/net/wireless/mediatek/mt76/mac80211.c
@@ -754,6 +754,8 @@ int mt76_register_device(struct mt76_dev *dev, bool vht,
 	set_bit(MT76_STATE_REGISTERED, &phy->state);
 	sched_set_fifo_low(dev->tx_worker.task);
 
+	mt76_ptp_init(dev);
+
 	return 0;
 }
 EXPORT_SYMBOL_GPL(mt76_register_device);
@@ -766,6 +768,8 @@ void mt76_unregister_device(struct mt76_dev *dev)
 	if (!test_bit(MT76_STATE_REGISTERED, &dev->phy.state))
 		return;
 
+	mt76_ptp_remove(dev);
+
 	if (IS_ENABLED(CONFIG_MT76_LEDS))
 		mt76_led_cleanup(&dev->phy);
 	mt76_tx_status_check(dev, true);
diff --git a/drivers/net/wireless/mediatek/mt76/ptp.c b/drivers/net/wireless/mediatek/mt76/ptp.c
new file mode 100644
--- /dev/null
+++ b/drivers/net/wireless/mediatek/mt76/ptp.c
@@ -0,0 +1,140 @@
+// SPDX-License-Identifier: ISC
+/*
+ * mt76 PTP hardware clock -- expose TSF as /dev/ptpN
+ *
+ * Common PTP implementation for all mt76 chipsets. Per-chipset TSF
+ * access is abstracted via mt76_ptp_ops callbacks, set during chipset
+ * init (mt7915_register_device, mt7921_register_device, etc.).
+ *
+ * For register-based chipsets (mt7915, mt7996), TSF read/write is a
+ * direct MMIO access. For firmware-based chipsets (mt7921), TSF access
+ * goes through MCU commands.
+ *
+ * TSF is in microseconds (802.11); PTP is in nanoseconds.
+ */
+
+#include <linux/ptp_clock_kernel.h>
+#include "mt76.h"
+
+static int mt76_ptp_gettime64(struct ptp_clock_info *ptp,
+			      struct timespec64 *ts)
+{
+	struct mt76_dev *dev = container_of(ptp, struct mt76_dev, ptp_info);
+	u64 tsf;
+
+	if (!dev->ptp_ops || !dev->ptp_ops->tsf_read)
+		return -EOPNOTSUPP;
+
+	mutex_lock(&dev->mutex);
+	tsf = dev->ptp_ops->tsf_read(dev);
+	mutex_unlock(&dev->mutex);
+
+	*ts = ns_to_timespec64((s64)tsf * NSEC_PER_USEC);
+	return 0;
+}
+
+static int mt76_ptp_settime64(struct ptp_clock_info *ptp,
+			      const struct timespec64 *ts)
+{
+	struct mt76_dev *dev = container_of(ptp, struct mt76_dev, ptp_info);
+	u64 tsf;
+
+	if (!dev->ptp_ops || !dev->ptp_ops->tsf_write)
+		return -EOPNOTSUPP;
+
+	tsf = div_u64(timespec64_to_ns(ts), NSEC_PER_USEC);
+
+	mutex_lock(&dev->mutex);
+	dev->ptp_ops->tsf_write(dev, tsf);
+	mutex_unlock(&dev->mutex);
+
+	return 0;
+}
+
+static int mt76_ptp_adjtime(struct ptp_clock_info *ptp, s64 delta_ns)
+{
+	struct mt76_dev *dev = container_of(ptp, struct mt76_dev, ptp_info);
+	u64 tsf;
+	s64 delta_usec;
+
+	if (!dev->ptp_ops || !dev->ptp_ops->tsf_read || !dev->ptp_ops->tsf_write)
+		return -EOPNOTSUPP;
+
+	delta_usec = div_s64(delta_ns, NSEC_PER_USEC);
+
+	mutex_lock(&dev->mutex);
+	tsf = dev->ptp_ops->tsf_read(dev);
+	dev->ptp_ops->tsf_write(dev, tsf + delta_usec);
+	mutex_unlock(&dev->mutex);
+
+	return 0;
+}
+
+static int mt76_ptp_adjfine(struct ptp_clock_info *ptp, long scaled_ppm)
+{
+	/* WiFi cards have fixed oscillators -- no frequency tuning. */
+	return 0;
+}
+
+static int mt76_ptp_getcrosststamp(struct ptp_clock_info *ptp,
+				   struct system_device_crosststamp *cts)
+{
+	struct mt76_dev *dev = container_of(ptp, struct mt76_dev, ptp_info);
+	u64 tsf;
+
+	if (!dev->ptp_ops || !dev->ptp_ops->tsf_read)
+		return -EOPNOTSUPP;
+
+	mutex_lock(&dev->mutex);
+	cts->sys_monoraw = ktime_get_raw();
+	tsf = dev->ptp_ops->tsf_read(dev);
+	cts->sys_realtime = ktime_get_real();
+	mutex_unlock(&dev->mutex);
+
+	cts->device = ns_to_ktime((s64)tsf * NSEC_PER_USEC);
+	return 0;
+}
+
+void mt76_ptp_init(struct mt76_dev *dev)
+{
+	struct ptp_clock_info *info = &dev->ptp_info;
+	struct device *parent;
+
+	if (!dev->ptp_ops) {
+		dev_dbg(dev->dev, "no PTP ops registered, skipping PTP clock\n");
+		return;
+	}
+
+	memset(info, 0, sizeof(*info));
+	info->owner = THIS_MODULE;
+	snprintf(info->name, sizeof(info->name), "mt76-%s",
+		 wiphy_name(dev->hw->wiphy));
+	info->max_adj = 500000000;
+	info->gettime64 = mt76_ptp_gettime64;
+	info->settime64 = dev->ptp_ops->tsf_write ? mt76_ptp_settime64 : NULL;
+	info->adjtime = dev->ptp_ops->tsf_write ? mt76_ptp_adjtime : NULL;
+	info->adjfine = mt76_ptp_adjfine;
+	info->getcrosststamp = mt76_ptp_getcrosststamp;
+
+	parent = dev->dev;
+	dev->ptp_clock = ptp_clock_register(info, parent);
+	if (IS_ERR(dev->ptp_clock)) {
+		dev_err(dev->dev, "PTP clock registration failed: %ld\n",
+			PTR_ERR(dev->ptp_clock));
+		dev->ptp_clock = NULL;
+		return;
+	}
+
+	dev_info(dev->dev, "registered PTP clock (ptp%d)\n",
+		 ptp_clock_index(dev->ptp_clock));
+}
+EXPORT_SYMBOL_GPL(mt76_ptp_init);
+
+void mt76_ptp_remove(struct mt76_dev *dev)
+{
+	if (dev->ptp_clock) {
+		ptp_clock_unregister(dev->ptp_clock);
+		dev->ptp_clock = NULL;
+	}
+}
+EXPORT_SYMBOL_GPL(mt76_ptp_remove);
